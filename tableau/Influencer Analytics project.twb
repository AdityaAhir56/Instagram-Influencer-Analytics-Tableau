      <column aggregation='None' datatype='integer' name='[Avg No of Likes (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='4' formula='[Avg_No_of_Likes]' peg='0' size='850507' />
      </column>
      <column aggregation='None' caption='Avg No of likes on new posts (bin)' datatype='integer' name='[Avg No of likes on new posts (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='4' formula='[Avg_No_of_likes_on_new_posts]' peg='0' size='655652' />
      </column>
      <column caption='Avg No of Likes' datatype='integer' name='[Avg_No_of_Likes]' role='measure' type='quantitative' />
      <column caption='Avg No of likes on new posts' datatype='integer' name='[Avg_No_of_likes_on_new_posts]' role='measure' type='quantitative' />
      <column caption='Like-To-Follower' datatype='real' name='[Calculation_0379656462860288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Total_No_of_likes]) / AVG([No_of_Followers])' />
      </column>
      <column caption='Calculation1' datatype='integer' name='[Calculation_0379656745000961]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Country_of_User])' />
      </column>
      <column caption='Engagement Rate' datatype='real' name='[Calculation_0680920530857984]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Avg_No_of_Likes] / [No_of_Followers]) * 100' />
      </column>
      <column caption='Growth rate in avg likes' datatype='real' name='[Calculation_0680920531357697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Avg_No_of_likes_on_new_posts] - [Avg_No_of_Likes]) / [Avg_No_of_Likes] * 100' />
      </column>
      <column caption='Rank Based on Influence Score' datatype='integer' name='[Calculation_1292250713878534]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Influence_Score]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Country of User' datatype='string' name='[Country_of_User]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column caption='Engagement rate of last 60 days in Percentage' datatype='real' name='[Engagement_rate_of_last_60_days_in_Percentage]' role='measure' type='quantitative' />
      <column aggregation='None' caption='Influence Score (bin)' datatype='integer' name='[Influence Score (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='-2' formula='[Influence_Score]' peg='0' size='6.75' />
      </column>
      <column caption='Influence Score' datatype='integer' name='[Influence_Score]' role='measure' type='quantitative' />
      <column aggregation='None' caption='No of Followers (bin)' datatype='integer' name='[No of Followers (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='4' formula='[No_of_Followers]' peg='0' size='2e+07' />
      </column>
      <column caption='No of Followers' datatype='integer' name='[No_of_Followers]' role='measure' type='quantitative' />
